<div class="max-w-md w-full bg-white/80 backdrop-blur rounded-3xl shadow-xl p-6 border border-pink-100">
  <h1 class="text-2xl font-bold text-center text-pink-600 mb-6">
    ✿ gauge calculator ✿
  </h1>

  <p class="text-sm text-gray-500 text-center mb-6">
    measure a swatch, enter your numbers, and we'll do the math for you! <br>
    <span class="text-xs">pro tip: block your swatch before measuring for best results</span>
  </p>

  <div id="errorBanner" class="hidden bg-red-50 border border-red-200 text-red-600 text-sm rounded-xl p-3 mb-4"></div>

  <div class="mb-4">
    <label for="unit" class="block text-sm font-semibold text-gray-700 mb-1">units</label>
    <select id="unit" onchange="updateUnitLabels()"
      class="w-full p-3 rounded-xl border border-pink-200 focus:outline-none focus:ring-2 focus:ring-pink-300 bg-white">
      <option value="inches" selected>inches</option>
      <option value="centimeters">centimeters</option>
    </select>
  </div>

  <div class="space-y-5">
    <p class="text-sm text-gray-500 mb-2">your swatch ✿</p>

    <div>
      <label for="stitches" class="block text-sm font-semibold text-gray-700">
        stitches in your swatch
      </label>
      <p class="text-xs text-gray-400 mb-1">
        count how many stitches are inside your measured section
      </p>
      <input id="stitches" type="number" value="18"
        class="w-full p-3 rounded-xl border border-pink-200 focus:outline-none focus:ring-2 focus:ring-pink-300">
    </div>

    <div>
      <label for="rows" class="block text-sm font-semibold text-gray-700">
        rows in your swatch
      </label>
      <p class="text-xs text-gray-400 mb-1">
        count the rows in the same section
      </p>
      <input id="rows" type="number" value="24"
        class="w-full p-3 rounded-xl border border-pink-200 focus:outline-none focus:ring-2 focus:ring-pink-300">
    </div>

    <div>
      <label for="width" class="block text-sm font-semibold text-gray-700">
        width you measured (<span class="unitLabel">inches</span>)
      </label>
      <p class="text-xs text-gray-400 mb-1">
        measure your swatch area (ignore the edges!)
      </p>
      <input id="width" type="number" value="4"
        class="w-full p-3 rounded-xl border border-pink-200 focus:outline-none focus:ring-2 focus:ring-pink-300">
    </div>

    <button onclick="calculateGauge()"
      class="w-full bg-pink-500 hover:bg-pink-600 text-white font-medium p-3 rounded-xl transition">
      calculate my gauge!
    </button>
  </div>

  <div class="mt-6 grid grid-cols-2 gap-3">
    <div class="bg-pink-50 rounded-xl p-4 text-center tooltip">
      <p class="text-xs text-gray-500 flex items-center justify-center gap-1">
        SPI
        <span class="text-gray-400">ⓘ</span>
      </p>

      <p id="spi" class="text-lg font-bold text-pink-600"></p>

      <div class="tooltip-text">
        stitches per <span class="unitLabelSingular">inch</span> - how many stitches fit in one <span class="unitLabelSingular">inch</span> of your fabric
      </div>
    </div>

    <div class="bg-blue-50 rounded-xl p-4 text-center tooltip">
      <p class="text-xs text-gray-500 flex items-center justify-center gap-1">
        RPI
        <span class="text-gray-400">ⓘ</span>
      </p>

      <p id="rpi" class="text-lg font-bold text-blue-600"></p>

      <div class="tooltip-text">
        rows per <span class="unitLabelSingular">inch</span> - how many rows fit in one <span class="unitLabelSingular">inch</span> of your fabric
      </div>
    </div>
  </div>

  <div class="my-6 border-t border-dashed border-pink-200"></div>
  <p class="text-sm text-gray-500 mb-2 mt-6">project sizing</p>

  <div class="space-y-3">
    <div class="mt-6 space-y-5">
      <div>
        <label for="targetWidth" class="block text-sm font-semibold text-gray-700">
          desired width of your project (<span class="unitLabel">inches</span>)
        </label>
        <p class="text-xs text-gray-400 mb-1">
          how wide do you want the finished piece?
        </p>
        <input id="targetWidth" type="number" value="38"
          class="w-full p-3 rounded-xl border border-blue-200 focus:outline-none focus:ring-2 focus:ring-blue-300">
      </div>
    </div>

    <button onclick="calculateStitches()"
      class="w-full bg-blue-500 hover:bg-blue-600 text-white font-medium p-3 rounded-xl transition">
      calculate stitches 🧶
    </button>

    <div class="bg-blue-50 rounded-xl p-4 text-center">
      <p class="text-xs text-gray-500">you need</p>
      <p id="stitchResult" class="text-lg font-bold text-blue-600"></p>
    </div>
  </div>

  <div class="mt-6 space-y-3">
    <div>
      <label for="targetHeight" class="block text-sm font-semibold text-gray-700">
        desired height of your project (<span class="unitLabel">inches</span>)
      </label>
      <p class="text-xs text-gray-400 mb-1">
        how tall do you want the finished piece?
      </p>
      <input id="targetHeight" type="number" value="10"
        class="w-full p-3 rounded-xl border border-pink-200 focus:outline-none focus:ring-2 focus:ring-pink-300">
    </div>

    <button onclick="calculateRows()"
      class="w-full bg-pink-500 hover:bg-pink-600 text-white font-medium p-3 rounded-xl transition">
      calculate rows 🧶
    </button>

    <div class="bg-pink-50 rounded-xl p-4 text-center">
      <p class="text-xs text-gray-500">you need</p>
      <p id="rowResult" class="text-lg font-bold text-pink-600"></p>
    </div>
  </div>

  <div class="mt-6 space-y-5">
    <div class="my-6 border-t border-dashed border-pink-200"></div>

    <p class="text-sm text-gray-500">pattern details ✿</p>
    <p class="text-xs text-gray-500 leading-relaxed">
      if your pattern repeats (like k2, p2), we'll adjust your stitch count so it fits perfectly ✨<br>
      <span class="text-gray-400">
        leave these blank if you're not using a repeat
      </span>
    </p>

    <div>
      <label for="repeat" class="block text-sm font-semibold text-gray-700">
        pattern repeat size
      </label>
      <p class="text-xs text-gray-400 mb-1">
        number of stitches in one repeat<br>
        <span class="text-gray-500">example: k2, p2 -> repeat of 4</span>
      </p>
      <input id="repeat" type="number" placeholder="optional"
        class="w-full p-3 rounded-xl border border-purple-200 focus:outline-none focus:ring-2 focus:ring-purple-300">
      <p class="text-[11px] text-gray-300 mt-1">
        total stitches = (repeat x n) + offset
      </p>
    </div>

    <div>
      <label for="offset" class="block text-sm font-semibold text-gray-700">
        extra stitches outside the repeat
      </label>
      <p class="text-xs text-gray-400 mb-1">
        stitches outside the repeat (edges, borders, etc.)<br>
        <span class="text-gray-500">example: +2 for edge stitches</span>
      </p>
      <input id="offset" type="number" value="0"
        class="w-full p-3 rounded-xl border border-purple-200 focus:outline-none focus:ring-2 focus:ring-purple-300">

      <p class="text-[11px] text-gray-300 mt-1">
        total stitches = (repeat x n) + offset
      </p>
    </div>
  </div>
</div>

<script src="/js/gauge.js"></script>
