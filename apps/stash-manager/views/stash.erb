<div class="max-w-2xl mx-auto p-6 mt-8">
  <div class="flex justify-between items-center mb-2">
    <h1 class="text-3xl font-bold text-teal-800">yarn stash manager</h1>
    <form method="post" action="/logout">
      <button type="submit" class="text-sm text-gray-500 hover:text-teal-700 transition">Sign out</button>
    </form>
  </div>
  <p class="text-center text-gray-600 mb-6">Track your yarn collection and check if you have enough for your next project.</p>

  <div class="bg-white rounded-xl shadow-md p-6 mb-6">
    <h2 class="text-lg font-semibold text-teal-700 mb-4">Add Yarn to Stash</h2>

    <div class="grid grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Brand</label>
        <input type="text" id="brand" class="w-full border rounded px-3 py-2" placeholder="e.g. Malabrigo">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Line</label>
        <input type="text" id="line" class="w-full border rounded px-3 py-2" placeholder="e.g. Rios">
      </div>
    </div>

    <div class="grid grid-cols-3 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Colorway</label>
        <input type="text" id="colorway" class="w-full border rounded px-3 py-2" placeholder="e.g. Azul Profundo">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Yardage/skein</label>
        <input type="number" id="yardage" step="any" min="0" class="w-full border rounded px-3 py-2" placeholder="210">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Weight (g)</label>
        <input type="number" id="skein_weight" step="any" min="0" class="w-full border rounded px-3 py-2" placeholder="100">
      </div>
    </div>

    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700 mb-1">Quantity (skeins)</label>
      <input type="number" id="quantity" min="1" value="1" class="w-full border rounded px-3 py-2">
    </div>

    <button onclick="addToStash()" class="w-full bg-teal-600 text-white font-semibold py-2 px-4 rounded hover:bg-teal-700 transition">
      Add to stash
    </button>
  </div>

  <div class="bg-white rounded-xl shadow-md p-6 mb-6">
    <h2 class="text-lg font-semibold text-teal-700 mb-4">Check Yardage</h2>
    <div class="flex gap-4">
      <input type="number" id="required_yardage" step="any" min="0" class="flex-1 border rounded px-3 py-2" placeholder="Required yards">
      <button onclick="checkYardage()" class="bg-teal-600 text-white font-semibold py-2 px-4 rounded hover:bg-teal-700 transition">
        Check
      </button>
    </div>
    <div id="check-result" class="hidden mt-4 p-3 rounded"></div>
  </div>

  <div class="bg-white rounded-xl shadow-md p-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-lg font-semibold text-teal-700">Your Stash</h2>
      <input type="text" id="search" oninput="loadStash()" class="border rounded px-3 py-2 text-sm" placeholder="Search...">
    </div>
    <div id="stash-list"></div>
    <div id="empty-stash" class="hidden text-center text-gray-500 py-4">
      Your stash is empty. Add some yarn!
    </div>
  </div>

  <div id="error" class="hidden bg-red-50 rounded-xl shadow-md p-4 text-red-700 mt-4"></div>
</div>

<script src="/js/stash.js"></script>
