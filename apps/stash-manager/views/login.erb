<div class="max-w-md mx-auto p-6 mt-8">
  <h1 class="text-3xl font-bold text-center text-teal-800 mb-2">yarn stash manager</h1>
  <p class="text-center text-gray-600 mb-6">Sign in to manage your stash.</p>

  <div class="bg-white rounded-xl shadow-md p-6">
    <h2 class="text-lg font-semibold text-teal-700 mb-4">Log In</h2>

    <form id="login-form">
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">Username</label>
        <input type="text" id="username" name="username" required class="w-full border rounded px-3 py-2" autofocus>
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
        <input type="password" id="password" name="password" required class="w-full border rounded px-3 py-2">
      </div>

      <button type="submit" class="w-full bg-teal-600 text-white font-semibold py-2 px-4 rounded hover:bg-teal-700 transition">
        Log In
      </button>
    </form>

    <p class="text-center text-sm text-gray-500 mt-4">
      Don't have an account? <a href="/signup" class="text-teal-600 hover:underline">Sign up</a>
    </p>

    <div id="error" class="hidden bg-red-50 rounded p-3 text-red-700 mt-4 text-sm"></div>
  </div>
</div>

<script src="/js/auth.js"></script>
